{
  "name": "secab-couplage-expert-premium-v20-corrige",
  "version": "20.3.0",
  "private": true,
  "description": "SECAB Couplage Expert Premium V20.3 - correction onglet Registre EDF / DOE et synchronisation packages.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "npx vite --host 0.0.0.0",
    "build": "npx vite build",
    "preview": "npx vite preview",
    "start": "electron .",
    "dist:win": "npm run build && npx electron-builder --win nsis portable --publish never",
    "android:sync": "npm run build && npx cap sync android",
    "android:debug": "npm run android:sync && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "6.2.0",
    "@capacitor/core": "6.2.0",
    "@capacitor/filesystem": "6.0.1",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.3.1",
    "vite": "5.4.11",
    "electron": "31.7.7",
    "electron-builder": "25.1.8"
  },
  "build": {
    "appId": "re.secab.couplage.expert",
    "productName": "SECAB Couplage Expert Premium",
    "directories": {
      "output": "release/windows"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "SECAB-Couplage-Expert-Premium-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}